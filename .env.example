# Copy this to .env and fill in. .env is gitignored (local/secret values).
#
# ONE database everywhere: PostgreSQL. Local dev and production run the SAME
# schema on the SAME engine — they differ only by this connection string
# (your machine's Postgres locally; a Neon Postgres URL in production).
# There is no SQLite and no second database anywhere.

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://postgres@127.0.0.1:5432/ecom_analytics?schema=public"
# In production, set this in the host's env vars to your Neon POOLED URL, e.g.:
# postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require

# --- Auth ---
# Secret that signs session cookies. Use a long random value in production.
AUTH_SECRET="dev-secret-change-me-in-production-0123456789abcdef"
