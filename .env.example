# Copy to .env and fill in. .env is gitignored (it holds local/secret values).

# --- Database (PostgreSQL) ---
# Local dev (a Postgres server running on your machine):
DATABASE_URL="postgresql://postgres@127.0.0.1:5432/ecom_analytics?schema=public"
# Production example (Neon — use the POOLED connection string it gives you):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# --- Auth ---
# Secret used to sign session cookies. Generate a long random value for production.
AUTH_SECRET="dev-secret-change-me-in-production-0123456789abcdef"
